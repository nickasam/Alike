# ============================================================
# Alike 环境变量模板
# 复制为 .env 后填入真实值：  cp .env.example .env
# 切勿把真实密码 / 密钥提交到仓库
# ============================================================

# ---------- 通用 ----------
APP_ENV=development          # development / production
TZ=Asia/Shanghai

# ---------- 后端 ----------
BACKEND_PORT=8080            # Go 后端监听端口（容器内）
GIN_MODE=debug              # debug / release
LOG_LEVEL=info

# ---------- 前端 ----------
FRONTEND_PORT=3000          # Nuxt 监听端口（容器内）
# 浏览器侧 API 基址（经 Nginx 反代，通常留空走同源 /api）
NUXT_PUBLIC_API_BASE=/api
NUXT_PUBLIC_WS_BASE=/ws

# ---------- 对外入口 ----------
NGINX_HTTP_PORT=80          # Nginx 对外 HTTP 端口

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres      # 容器间用 service name 互联
POSTGRES_PORT=5432
POSTGRES_USER=alike
POSTGRES_PASSWORD=changeme_postgres_password   # 占位符，请替换
POSTGRES_DB=alike
# 宿主机映射端口（本地连库调试用）
POSTGRES_HOST_PORT=5432

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password         # 占位符，请替换（留空则无密码）
REDIS_DB=0
REDIS_HOST_PORT=6379

# ---------- JWT ----------
JWT_SECRET=changeme_super_secret_jwt_key       # 占位符，请替换为高强度随机串
JWT_ACCESS_TTL=15m          # access token 有效期
JWT_REFRESH_TTL=168h        # refresh token 有效期（7 天）

# ---------- MinIO / S3 ----------
MINIO_ROOT_USER=alike_minio_admin
MINIO_ROOT_PASSWORD=changeme_minio_password    # 占位符，请替换（≥8 位）
MINIO_ENDPOINT=minio:9000   # 后端访问 MinIO 的地址（容器内）
MINIO_BUCKET=alike-uploads  # 默认 bucket，由 createbuckets 服务自动创建
MINIO_USE_SSL=false
MINIO_API_PORT=9000         # S3 API 宿主机端口
MINIO_CONSOLE_PORT=9001     # 控制台宿主机端口

# ---------- 文件上传 ----------
UPLOAD_MAX_IMAGE_MB=5
UPLOAD_MAX_DOC_MB=10
