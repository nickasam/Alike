# Alike 后端环境变量示例，复制为 .env 使用
APP_ENV=development
SERVER_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=alike
DB_PASSWORD=alike
DB_NAME=alike
DB_SSLMODE=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=alike-dev-secret-change-me
JWT_ACCESS_EXPIRE_MIN=120
JWT_REFRESH_EXPIRE_HOUR=168

# 对象存储（MinIO / S3）
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=alike_minio_admin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=alike-uploads
MINIO_USE_SSL=false
# 浏览器可达的对象存储 base（生产填公网域名/IP，如 http://39.107.58.169）
# 留空会 fallback 到 http://MINIO_ENDPOINT（内网地址，浏览器无法访问）
MINIO_PUBLIC_URL=http://localhost
UPLOAD_MAX_IMAGE_MB=5
UPLOAD_MAX_DOC_MB=10
